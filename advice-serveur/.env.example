# API Keys for External Services
AGENT_PROVIDER=groq
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
BRAVE_API_KEY=your_brave_search_api_key_here
SERPER_API_KEY=your_serper_api_key_here
SEARXNG_BASE_URL=http://localhost:8080
SEARXNG_TIMEOUT=20

# UCAR Internal API Configuration
UCAR_INTERNAL_API_URL=https://api.ucar.edu.tn/v1
UCAR_INTERNAL_API_KEY=your_ucar_internal_api_key_here

# General Project Configuration
UCAR_NAME="University of Carthage"
# Leave empty to auto-pick the top 10 universities ranked above UCAR from the downloaded Excel.
COMPETITORS=
DATA_DIR=./data
REPORTS_DIR=./reports

# Scraper & Job Settings
WEBOMETRICS_EXCEL_URL=https://www.webometrics.info/en/system/files/excel/ranking.xlsx
CRON_SCHEDULE="0 6 * * 1"
